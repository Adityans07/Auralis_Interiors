def slugify(value: str) -> str:
    """Convert string to URL-friendly slug"""
    return (
        value.lower()
        .replace("/", "-")
        .replace(" ", "-")
        .replace("–", "-")
        .replace("&", "and")
        .replace("(", "")
        .replace(")", "")
        .replace(",", "")
        .replace(".", "")
        .replace("--", "-")
    )


def get_random_price(base_price: int, variation: float = 0.3) -> int:
    """Generate a realistic price with some variation"""
    variation_amount = int(base_price * variation)
    return max(
        base_price - variation_amount,
        base_price + random.randint(-variation_amount, variation_amount),
    )


def get_random_stock_status() -> StockStatus:
    """Return a random stock status weighted toward in-stock"""
    rand = random.random()
    if rand < 0.7:
        return StockStatus.IN_STOCK
    elif rand < 0.9:
        return StockStatus.LIMITED
    else:
        return StockStatus.OUT_OF_STOCK


