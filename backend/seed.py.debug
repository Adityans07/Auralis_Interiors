    # Create products from templates with variations
    for template in product_templates:
        category_key = template["key"]

        # Create 2-4 variations of each template
        num_variations = random.randint(2, 4)

        for i in range(num_variations):
            # Generate realistic price variation
            base_price = template["base_price"]
            price = get_price_for_category(category_key)

            # Sometimes apply discount
            discount = random.choice([0, 0, 0, 5, 10, 15, 20])  # Mostly no discount
            if discount > 0:
                discounted_price = int(price * (1 - discount/100))
            else:
                discounted_price = price

            # Select random attributes
            brand = get_brand_for_category(category_key)
            material = get_material_for_category(category_key)
            style = random.choice(STYLE_OPTIONS)

            # Generate color variations
            base_color = template["color"]
            colors = [base_color]
            if "Wood" in material or "wood" in material.lower():
                colors.extend(["Natural", "Walnut", "Oak", "Mahogany", "Cherry", "Espresso", "White"])
            elif "Metal" in material or "metal" in material.lower():
                colors.extend(["Black", "White", "Silver", "Gold", "Bronze", "Gray"])
            elif "Fabric" in material or "fabric" in material.lower():
                colors.extend(["Beige", "Gray", "Blue", "Green", "Red", "Yellow", "Pink"])
            elif "Glass" in material or "glass" in material.lower():
                colors.extend(["Clear", "Frosted", "Tinted"])
            else:
                colors.extend(["White", "Black", "Gray", "Beige", "Brown"])

            color = random.choice(colors)

            # Generate dimensions with slight variation
            dimensions = template["dimensions"]

            # Generate SKU/slug
            name_for_slug = f"{template['name']} {color} {style}"
            slug = slugify(name_for_slug)

            # Select random Indian city
            city, state = random.choice(INDIAN_CITIES)

            # Generate features list (sometimes modify)
            features = template["features"].copy()
            if random.random() < 0.3:  # 30% chance to add a feature
                extra_features = [
                    "Easy assembly",
                    "Warranty included",
                    "Free shipping",
                    "Eco-friendly materials",
                    "Child safe",
                    "Fire resistant",
                    "Water resistant",
                    "UV protected"
                ]
                features.append(random.choice(extra_features))

            # Generate description variations
            description = template["description"]
            if random.random() < 0.4:  # 40% chance to enhance description
                enhancers = [
                    "Perfect for modern Indian homes.",
                    "Ideal for small apartments and spacious villas alike.",
                    "Combines functionality with aesthetic appeal.",
                    "Designed for comfort and durability.",
                    "Adds elegance to any living space.",
                    "Easy to maintain and clean.",
                    "Environmentally friendly materials used.",
                    "Comes with manufacturer warranty."
                ]
                description += " " + random.choice(enhancers)

            # Create final product
            product = {
                "key": category_key,
                "name": f"{template['name']} - {color}",
                "description": description,
                "features": features,
                "style": style,
                "material": material,
                "color": color,
                "dimensions": dimensions,
                "base_price": price,
                "discount_percent": discount,
                "final_price": discounted_price,
                "stock_status": get_random_stock_status(),
                "brand": brand,
                "city": city,
                "state": state,
                "country": "India",
            }

            products.append(product)

    return products


