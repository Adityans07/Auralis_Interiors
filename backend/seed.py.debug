def main() -> None:
    """Main seeding function"""
    db = SessionLocal()
    try:
        # Create admin user if doesn't exist
        if settings.admin_email and settings.admin_password and settings.admin_name:
            admin_email = normalize_email(settings.admin_email)
            existing_admin = db.query(User).filter(User.email == admin_email).one_or_none()
            if existing_admin:
                if existing_admin.role != UserRole.ADMIN.value:
                    existing_admin.role = UserRole.ADMIN.value
                if existing_admin.status != UserStatus.ACTIVE.value:
                    existing_admin.status = UserStatus.ACTIVE.value
                if not existing_admin.name:
                    existing_admin.name = settings.admin_name
            else:
                print("ADMIN_EMAIL:", repr(settings.admin_email))
                print("ADMIN_NAME:", repr(settings.admin_name))
                print("ADMIN_PASSWORD:", repr(settings.admin_password))
                print("PASSWORD LENGTH:", len(settings.admin_password or ""))
                user = User(
                    name=settings.admin_name,
                    email=admin_email,
                    password_hash=hash_password(settings.admin_password),
                    role=UserRole.ADMIN.value,
                    status=UserStatus.ACTIVE.value,
                    email_verified_at=datetime.now(timezone.utc),
                )
                db.add(user)
                db.flush()
                db.add(UserUsage(user_id=user.id))

        # Clear existing products and blogs (optional - comment out if you want to keep existing)
        # Uncomment the following lines if you want to completely replace existing data
        # print("Clearing existing product data...")
        # db.query(Product).delete()
        # db.query(BlogPost).delete()
        # db.flush()

        # Create products
        print("Creating products...")
        products_data = create_comprehensive_products()
        product_count = 0

        for product_data in products_data:
            slug = slugify(f"{product_data['name']}-{product_data['city']}")
            product = db.query(Product).filter(Product.slug == slug).one_or_none()

            data = {
                "name": product_data["name"],
                "slug": slug,
                "category": PRODUCT_CATEGORIES[product_data["key"]]["category"],
                "subcategory": PRODUCT_CATEGORIES[product_data["key"]]["subcategory"],
                "description": product_data["description"],
                "price": product_data["final_price"],
                "currency": "INR",
                "image_url": f"https://picsum.photos/seed/{slug}/800/600",
                "brand": product_data["brand"],
                "material": product_data["material"],
                "color": product_data["color"],
                "style_tags": [product_data["style"]],
                "item_type": product_data["key"],
                "room_types": PRODUCT_CATEGORIES[product_data["key"]]["room_types"],
                "design_types": ["interior"],  # Most products are for interior use
                "city": product_data["city"],
                "state": product_data["state"],
                "country": product_data["country"],
                "postal_code": None,
                "stock_status": product_data["stock_status"],
                "vendor_name": "Quality Home Supplies India",
                "vendor_url": None,
            }

            # Add specific room types for outdoor products
            if "outdoor" in product_data["key"] or "garden" in product_data["key"] or "patio" in product_data["key"]:
                data["design_types"] = ["exterior"]
            elif "exterior" in product_data["key"] or "window" in product_data["key"] or "door" in product_data["key"]:
                data["design_types"] = ["exterior"]
            else:
                data["design_types"] = ["interior"]

            if product:
                # Update existing product
                for key, value in data.items():
                    setattr(product, key, value)
            else:
                # Create new product
                db.add(Product(**data))

            product_count += 1

            if product_count % 20 == 0:
                print(f"Created {product_count} products...")

        # Create blog posts
        print("Creating blog posts...")
        blogs_data = create_blog_posts()
        blog_count = 0

        for slug, title, category in blogs_data:
            post = db.query(BlogPost).filter(BlogPost.slug == slug).one_or_none()
            data = {
                "slug": slug,
                "title": title,
                "excerpt": "Expert insights and practical tips for creating beautiful, functional living spaces tailored for Indian homes.",
                "content": [
                    "Our design experts share valuable advice on current trends, timeless principles, and practical solutions for your home.",
                    "Learn how to make informed decisions about furniture, color schemes, lighting, and layout to create spaces that reflect your personality and lifestyle.",
                    "Special focus on Indian climate, cultural preferences, and traditional wisdom like Vaastu Shastra.",
                ],
                "cover_image_url": f"https://picsum.photos/seed/{slug}/1200/700",
                "author_name": "Auralis Design Team",
                "category": category,
                "tags": ["design", "interior", category.lower(), "india"],
                "published": True,
                "published_at": datetime.now(timezone.utc),
            }

            if post:
                for key, value in data.items():
                    setattr(post, key, value)
            else:
                db.add(BlogPost(**data))

            blog_count += 1

        # Commit all changes
        print(f"Committing {product_count} products and {blog_count} blog posts...")
        db.commit()
        print("✅ Seeding completed successfully!")

    except Exception as e:
        print(f"❌ Error during seeding: {e}")
        db.rollback()
        raise
    finally:
        db.close()


if __name__ == "__main__":
    main()