def get_price_for_category(category_key: str) -> int:
    """Get a random price for a category in INR"""
    low, high = PRICE_RANGES_INR.get(category_key, (1000, 50000))
    return random.randint(low, high)


def get_material_for_category(category_key: str) -> str:
    """Get appropriate material for category"""
    if "sofa" in category_key or "chair" in category_key or "seat" in category_key:
        return random.choice(MATERIAL_OPTIONS["chairs"])
    elif "table" in category_key:
        return random.choice(MATERIAL_OPTIONS["tables"])
    elif "storage" in category_key or "cabinet" in category_key or "wardrobe" in category_key or "drawer" in category_key:
        return random.choice(MATERIAL_OPTIONS["storage"])
    elif "bed" in category_key:
        return random.choice(MATERIAL_OPTIONS["beds"])
    elif "light" in category_key or "lamp" in category_key or "chandelier" in category_key:
        return random.choice(MATERIAL_OPTIONS["lighting"])
    elif "rug" in category_key:
        return random.choice(MATERIAL_OPTIONS["rugs"])
    elif "curtain" in category_key or "blind" in category_key or "pillow" in category_key or "throw" in category_key:
        return random.choice(MATERIAL_OPTIONS["curtains"])
    elif "mirror" in category_key or "art" in category_key or "vase" in category_key or "plant" in category_key:
        return random.choice(MATERIAL_OPTIONS["decor"])
    elif "tile" in category_key or "floor" in category_key or "wall" in category_key:
        return random.choice(["Ceramic", "Porcelain", "Marble", "Granite", "Wood", "Vinyl", "Laminate"])
    elif "door" in category_key or "window" in category_key:
        return random.choice(["Wood", "Metal", "UPVC", "Fiberglass", "Glass", "Aluminum"])
    else:
        return "Mixed Materials"


def get_brand_for_category(category_key: str) -> str:
    """Get appropriate brand for category"""
    if "sofa" in category_key or "chair" in category_key or "table" in category_key or "storage" in category_key or "bed" in category_key:
        return random.choice(INDIAN_BRANDS["furniture"])
    elif "light" in category_key or "lamp" in category_key or "chandelier" in category_key:
        return random.choice(INDIAN_BRANDS["lighting"])
    elif "curtain" in category_key or "blind" in category_key or "rug" in category_key or "pillow" in category_key or "throw" in category_key or "art" in category_key or "mirror" in category_key or "vase" in category_key or "plant" in category_key:
        return random.choice(INDIAN_BRANDS["decor"])
    elif "tile" in category_key or "floor" in category_key or "wall" in category_key or "door" in category_key or "window" in category_key:
        return random.choice(INDIAN_BRANDS["building_materials"])
    else:
        return random.choice(INDIAN_BRANDS["furniture"])  # fallback


